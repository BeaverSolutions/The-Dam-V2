# ─────────────────────────────────────────────────────
# The Dam v2 — Production Environment Variables
# Set these in Railway: Service → Variables
# ─────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3001

# Your Railway app URL (Railway provides this, or set after first deploy)
# Also used for OAuth redirects and CORS
FRONTEND_URL=https://your-app.up.railway.app

# Database
# Railway sets this automatically when you add a PostgreSQL database
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# Security — generate strong random values for production
# JWT_SECRET:        openssl rand -base64 64
# ENCRYPTION_KEY:    openssl rand -hex 32
# INTERNAL_API_KEY:  openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string-at-least-64-chars
ENCRYPTION_KEY=replace-with-64-char-hex-string-from-openssl-rand-hex-32
INTERNAL_API_KEY=replace-with-random-base64-string

# AI — required for agent pipeline
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=***REMOVED***...
OPENAI_API_KEY=
OPENAI_MODEL_REASONING=gpt-4.1
OPENAI_MODEL_FAST=gpt-4.1-mini

# Safety brake: continuous hourly KPI-gap kickoffs are opt-in.
# Leave false while validating sourcing/output paths; daily scheduled kickoff is separate.
CAPTAIN_KPI_GAP_KICKOFF_ENABLED=false
# Safety brake: 09:30 MYT autonomous daily kickoff is opt-in.
CAPTAIN_DAILY_KICKOFF_ENABLED=false
# Safety brake: 08:30 MYT market sensing uses Brave/LLM and is opt-in.
MARKET_SENSING_ENABLED=false
# Safety brake: Enforcer-approved drafts still require MJ approval unless this is explicitly true.
AUTO_APPROVE_ENABLED=false
# Safety brake: missed auto-approval recovery is separately opt-in; keep false unless MJ explicitly approves auto-sending.
AUTO_APPROVAL_RECOVERY_ENABLED=false
# Safety brake: Tier-B -> Tier-A pool email enrichment (08:45 MYT). Spends Brave + MillionVerifier; keep false until the money-approved proof run.
POOL_EMAIL_ENRICHMENT_ENABLED=false
# Safety brake: generic on-demand / VP scraping fallback in the autonomous kickoff loop. Off = signal hunt + enriched pool + Vibe CSV only (no generic paid burn for 0 output). Keep false; the no-burn boundary.
GENERIC_SOURCING_ENABLED=false
# Safety brake: all-tenant kickoff and dedupe force override are disabled by default.
KICKOFF_ALL_ENABLED=false
KICKOFF_FORCE_OVERRIDE_ENABLED=false
# Tenant allowlists. Empty means scheduled autonomous work is a no-op.
AUTONOMOUS_ENABLED_CLIENTS=beaver-solutions
DB_BUILDER_ENABLED_CLIENTS=beaver-solutions
# RLS global pool enforcement is off until the deploy database connection mode is validated.
RLS_ENFORCE_ENABLED=false
# Raw SQL admin endpoint stays disabled unless a supervised maintenance window explicitly enables it.
ADMIN_SQL_ENABLED=false
# Bounded web/LinkedIn Research caps.
DAILY_WEB_LINKEDIN_SIGNAL_CAP=6
DAILY_KICKOFF_SIGNAL_PREFILL_ENABLED=false
SIGNAL_HUNT_MAX_QUERIES=6
SIGNAL_HUNT_MAX_QUERY_WINDOW=20
SIGNAL_HUNT_RESULTS_PER_QUERY=3
CHANNEL_ESCALATION_DAILY_CAP=5
MAX_DAILY_SENDS=200

# AgentMail — server-wide key, Sales Beaver creates per-client inboxes automatically
AGENTMAIL_API_KEY=am_us_...
AGENTMAIL_WEBHOOK_SECRET=generate-a-random-string-32-chars

# Search (Research Beaver uses Brave for web search)
BRAVE_API_KEY=your-brave-api-key

# Metered-provider brakes. Keep zero until MJ approves quota use.
BRAVE_DAILY_QUERY_CAP=70
GOOGLE_CSE_DAILY_QUERY_CAP=0
LUSHA_DAILY_QUERY_CAP=0
SNOV_DAILY_QUERY_CAP=0
HUNTER_DAILY_QUERY_CAP=0
MILLIONVERIFIER_DAILY_VERIFY_CAP=0
APOLLO_DAILY_QUERY_CAP=0
SEARCH_MAX_PAID_QUERIES_PER_OPERATION=6
RESEARCH_MAX_PAID_QUERIES_PER_RUN=6
VP_DAILY_CREDIT_CAP=60
ALLOW_VP_PAID_ENRICHMENT=false
ALLOW_UNATTRIBUTED_LLM=false
ALLOW_UNATTRIBUTED_METERED_API=false

# Gmail OAuth — only needed if users connect Gmail accounts
# Create credentials at console.cloud.google.com
# GMAIL_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GMAIL_CLIENT_SECRET=your-google-client-secret
# GMAIL_REDIRECT_URI=https://your-app.up.railway.app/api/integrations/gmail/callback

# Lusha and Snov.io are server env keys for the email-sourcing waterfall.
# Keep their daily caps at 0 until MJ explicitly approves quota use.
# LUSHA_API_KEY=
# SNOV_CLIENT_ID=
# SNOV_CLIENT_SECRET=
# SNOV_RESULT_POLLS=2
# SNOV_RESULT_POLL_MS=750

# Apollo.io and Hunter.io API keys are stored per-client in the database
# (set via Settings UI — no env vars needed here)

# Telegram Bot (Jarvis)
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
# TELEGRAM_CHAT_ID=your-chat-id
# TELEGRAM_CLIENT_SLUG=beaver-solutions

# Discord Bot (optional)
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_CLIENT_ID=your-discord-client-id
# DISCORD_GUILD_ID=your-discord-guild-id
