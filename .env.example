DATABASE_URL=postgresql://postgres:postgres@db:5432/thedam

# ─── SECRETS — NEVER COMMIT REAL VALUES ──────────────────────────────────
# Generate JWT_SECRET with:       node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Generate ENCRYPTION_KEY with:    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate INTERNAL_API_KEY with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Rotating ENCRYPTION_KEY breaks decryption of stored integration tokens — in prod, plan a re-encryption migration first.
JWT_SECRET=REPLACE_ME_long_random_string
ENCRYPTION_KEY=REPLACE_ME_64_hex_chars
INTERNAL_API_KEY=***REMOVED***

PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# AI Agents — rotate at console.anthropic.com, store in Railway Variables in prod
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=***REMOVED***...
OPENAI_API_KEY=
OPENAI_MODEL_REASONING=gpt-4.1
OPENAI_MODEL_FAST=gpt-4.1-mini

# Safety brake: continuous hourly KPI-gap kickoffs are opt-in.
# Leave false while validating sourcing/output paths; daily scheduled kickoff is separate.
CAPTAIN_KPI_GAP_KICKOFF_ENABLED=false
# Safety brake: 09:30 MYT autonomous daily kickoff is opt-in.
CAPTAIN_DAILY_KICKOFF_ENABLED=false
# Safety brake: 08:30 MYT market sensing uses Brave/LLM and is opt-in.
MARKET_SENSING_ENABLED=false
# Safety brake: Enforcer-approved drafts still require MJ approval unless this is explicitly true.
AUTO_APPROVE_ENABLED=false
# Safety brake: missed auto-approval recovery is separately opt-in; keep false unless MJ explicitly approves auto-sending.
AUTO_APPROVAL_RECOVERY_ENABLED=false
# Safety brake: Tier-B -> Tier-A pool email enrichment (08:45 MYT). Spends Brave + MillionVerifier; keep false until the money-approved proof run.
POOL_EMAIL_ENRICHMENT_ENABLED=false
# Safety brake: generic on-demand / VP scraping fallback in the autonomous kickoff loop. Off = signal hunt + enriched pool + Vibe CSV only (no generic paid burn for 0 output). Keep false; the no-burn boundary.
GENERIC_SOURCING_ENABLED=false
# Safety brake: all-tenant kickoff and dedupe force override are disabled by default.
KICKOFF_ALL_ENABLED=false
KICKOFF_FORCE_OVERRIDE_ENABLED=false
# Tenant allowlists. Empty means scheduled autonomous work is a no-op.
AUTONOMOUS_ENABLED_CLIENTS=beaver-solutions
DB_BUILDER_ENABLED_CLIENTS=beaver-solutions
# RLS global pool enforcement is off until the deploy database connection mode is validated.
RLS_ENFORCE_ENABLED=false
# Raw SQL admin endpoint stays disabled unless a supervised maintenance window explicitly enables it.
ADMIN_SQL_ENABLED=false
# Bounded web/LinkedIn Research caps.
DAILY_WEB_LINKEDIN_SIGNAL_CAP=6
DAILY_KICKOFF_SIGNAL_PREFILL_ENABLED=false
SIGNAL_HUNT_MAX_QUERIES=6
SIGNAL_HUNT_MAX_QUERY_WINDOW=20
SIGNAL_HUNT_RESULTS_PER_QUERY=3
CHANNEL_ESCALATION_DAILY_CAP=5
MAX_DAILY_SENDS=200

# Third-party integrations
# Gmail + Google Calendar OAuth (same Google Cloud project, same client credentials)
# Enable both Gmail API and Google Calendar API in Google Cloud Console
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REDIRECT_URI=http://localhost:3001/api/integrations/gmail/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/integrations/calendar/callback

# AgentMail — server-wide key (get from agentmail.io dashboard)
# Sales Beaver creates per-client inboxes automatically using this key
AGENTMAIL_API_KEY=am_us_...
AGENTMAIL_WEBHOOK_SECRET=generate-a-random-string-32-chars

# Apollo.io — saved per-client via Settings UI (no env var needed)
# APOLLO_API_KEY is stored encrypted in the database per client

# Lusha — env key for email sourcing waterfall (Lusha -> Snov -> Hunter).
# Keep LUSHA_DAILY_QUERY_CAP=0 until MJ explicitly approves quota use.
LUSHA_API_KEY=

# Snov.io — env keys for email sourcing waterfall.
# Keep SNOV_DAILY_QUERY_CAP=0 until MJ explicitly approves quota use.
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
SNOV_RESULT_POLLS=2
SNOV_RESULT_POLL_MS=750

# Hunter.io — saved per-client via Settings UI (no env var needed)
# HUNTER_API_KEY is stored encrypted in the database per client

# Search — fallback chain: Brave → Google CSE → DuckDuckGo (no key needed)
BRAVE_API_KEY=your-brave-api-key
# Google Custom Search (fallback — 100 free queries/day)
# Get API key: console.cloud.google.com → Custom Search JSON API
# Get CX (search engine ID): programmablesearchengine.google.com → Create → enable "Search the entire web"
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Metered-provider brakes. Defaults in code fail closed for search/enrichment.
# Set a positive cap only when MJ explicitly approves spend/quota usage.
BRAVE_DAILY_QUERY_CAP=70
GOOGLE_CSE_DAILY_QUERY_CAP=0
LUSHA_DAILY_QUERY_CAP=0
SNOV_DAILY_QUERY_CAP=0
HUNTER_DAILY_QUERY_CAP=0
MILLIONVERIFIER_DAILY_VERIFY_CAP=0
APOLLO_DAILY_QUERY_CAP=0
SEARCH_MAX_PAID_QUERIES_PER_OPERATION=6
RESEARCH_MAX_PAID_QUERIES_PER_RUN=6
VP_DAILY_CREDIT_CAP=60
ALLOW_VP_PAID_ENRICHMENT=false
ALLOW_UNATTRIBUTED_LLM=false
ALLOW_UNATTRIBUTED_METERED_API=false

# Public URL for webhook registration (ngrok in dev, your domain in prod)
FRONTEND_URL=http://localhost:5173

# Telegram Bot (Jarvis)
TELEGRAM_BOT_TOKEN=***REMOVED***
TELEGRAM_WEBHOOK_SECRET=generate-a-random-string-32-chars
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_CLIENT_SLUG=beaver-solutions

# Discord Bot (optional — notifications to Discord)
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# MyClaw (OpenClaw) — director layer integration
# MYCLAW_HOOK_TOKEN: shared secret, MyClaw sends this to authenticate inbound requests to /api/myclaw/*
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# MYCLAW_WEBHOOK_URL: base URL of MyClaw's inbound webhook (The Dam pushes approval notifications here)
MYCLAW_HOOK_TOKEN=generate-a-random-string-43-chars
MYCLAW_WEBHOOK_URL=https://your-myclaw-instance.com
WHATSAPP_NUMBER=601115081530
